# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI API Key (server-side only)
OPENAI_API_KEY=your_openai_api_key

# Optional: Supabase auth user UUIDs (comma-separated) that skip the 3 meal scans / 24h cap
# MEAL_SCAN_UNLIMITED_USER_IDS=

# USDA API Key (optional, for food database search)
EXPO_PUBLIC_USDA_API_KEY=your_usda_api_key

# Backend API URL (for tRPC)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
