# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI API Key (server-side only)
OPENAI_API_KEY=your_openai_api_key
# Supabase service-role key for backend-only RPC/table access
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Manage unlimited-scan accounts in Supabase table: public.ai_scan_quota_bypass
#
# Referral / admin: grant dashboard SQL in supabase/migrations/20260329_referral_affiliate_system.sql
# Promote a user to admin (SQL editor): UPDATE public.profiles SET app_role = 'admin' WHERE id = 'USER_UUID';

# USDA API Key (optional, for food database search)
EXPO_PUBLIC_USDA_API_KEY=your_usda_api_key

# Backend API URL (for tRPC)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Staff/internal only: comma-separated emails treated as Premium (bypass paywall + sync). Not for end users.
EXPO_PUBLIC_PREMIUM_EMAIL_ALLOWLIST=

# Google Play subscription product IDs (must match Play Console; align prices with RevenueCat, e.g. Rp 69k monthly / Rp 279,999 yearly).
# EXPO_PUBLIC_ANDROID_SUBSCRIPTION_MONTHLY=dietku_premium_monthly
# EXPO_PUBLIC_ANDROID_SUBSCRIPTION_YEARLY=dietku_premium_yearly
# EXPO_PUBLIC_ANDROID_BASEPLAN_MONTHLY=monthly
# EXPO_PUBLIC_ANDROID_BASEPLAN_YEARLY=tahunan

# App Store subscription product IDs (optional fallback when Offering packages are empty; must match App Store Connect).
# EXPO_PUBLIC_IOS_SUBSCRIPTION_MONTHLY=dietku_monthly
# EXPO_PUBLIC_IOS_SUBSCRIPTION_YEARLY=dietku_yearly

# RevenueCat public SDK keys (safe to expose in client)
# Backward compatibility: EXPO_PUBLIC_REVENUECAT_API_KEY still works for Android.
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your_revenuecat_android_public_sdk_key
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your_revenuecat_ios_public_sdk_key
# Expo Go only: Test Store public key (RevenueCat → Apps & providers → Test Store). Do not use in App Store / Play release builds.
EXPO_PUBLIC_REVENUECAT_TEST_STORE_API_KEY=
