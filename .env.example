# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI API Key (server-side only)
OPENAI_API_KEY=your_openai_api_key
# Supabase service-role key for backend-only RPC/table access
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Manage unlimited-scan accounts in Supabase table: public.ai_scan_quota_bypass

# USDA API Key (optional, for food database search)
EXPO_PUBLIC_USDA_API_KEY=your_usda_api_key

# Backend API URL (for tRPC)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Optional: comma-separated emails treated as Premium (UI + syncs meal-scan bypass). Remove in production if unused.
EXPO_PUBLIC_PREMIUM_EMAIL_ALLOWLIST=

# RevenueCat public SDK keys (safe to expose in client)
# Backward compatibility: EXPO_PUBLIC_REVENUECAT_API_KEY still works for Android.
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your_revenuecat_android_public_sdk_key
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your_revenuecat_ios_public_sdk_key
